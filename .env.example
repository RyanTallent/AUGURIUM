# Copy to .env and adjust as needed
DATABASE_URL="postgresql://augurium:augurium@localhost:5432/augurium"
REDIS_URL="redis://localhost:6379"
# Phase E — Discord intelligence (advisory alerts only)
DISCORD_ENABLED=false
DISCORD_WEBHOOK_URL=""
AUGURIUM_DASHBOARD_URL="http://localhost:3000"

# Polymarket public APIs
POLYMARKET_GAMMA_BASE="https://gamma-api.polymarket.com"
POLYMARKET_DATA_BASE="https://data-api.polymarket.com"

# Phase A ingestion tuning (optional)
INGEST_MARKETS_PAGE_SIZE=50
INGEST_MARKETS_MAX_PAGES_ACTIVE=10
INGEST_MARKETS_MAX_PAGES_CLOSED=6
INGEST_MARKETS_MAX_PAGES_EVENTS=4
INGEST_TRADES_PAGE_SIZE=100
INGEST_TRADES_MAX_PAGES=5
TRADE_LINK_BATCH_SIZE=500
TRADE_LINK_MAX_BATCHES=20
WALLET_DISCOVER_MARKETS_PER_RUN=15
WALLET_ACTIVITY_BATCH_SIZE=5
POSITION_SYNC_BATCH_SIZE=10
WORKER_POLL_INTERVAL_MS=30000

# Phase F — simulated portfolio (no live execution)
INITIAL_TRADING_BANKROLL_USD=70
MAX_DAILY_LOSS_USD=25
MAX_CATEGORY_EXPOSURE_PCT=0.4
PORTFOLIO_MAX_SIGNALS=150

# Phase G — execution (disabled by default; no live trading in verify)
EXECUTION_ENABLED=false
EXECUTION_PROVIDER=paper
LIVE_TRADING_ENABLED=false
ALLOW_REAL_MONEY=false
MAX_SLIPPAGE_BPS=100
EXECUTION_MAX_DECISIONS=50
POLYMARKET_PRIVATE_KEY=
POLYMARKET_API_KEY=
POLYMARKET_API_SECRET=
POLYMARKET_API_PASSPHRASE=
POLYMARKET_FUNDER_ADDRESS=
